": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "nm",\u000a\u0009\u0009\u0009\u0009\u0009"label": "size",\u000a\u0009\u0009\u0009\u0009\u0009"name": "buttonSize",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "small",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "sm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "normal",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "nm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "large",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "lg"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009]\u000a\u0009\u0009}\u000a\u0009]\u000a}','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"next-button-text":{"defaultValue":"\n\t\t\t\tNext\n\t\t\t","config":{}},"previous-button-text":{"defaultValue":"\n\t\t\t\tPrevious\n\t\t\t","config":{}},"submit-button-text":{"defaultValue":"\n\t\tSubmit\n\t","en_US":"Next","config":{}}},"com.liferay.fragment.entry.processor.freemarker.FreeMarkerFragmentEntryProcessor":{"buttonType":"primary","submittedEntryStatus":"2","buttonSize":"nm"}}','vhrj',0,'INPUTS-submit-button',3,'2025-07-25 12:56:00.459000',NULL,'713387fe-7542-f938-1b6e-f7f72e7e6f7f')
