INSERT INTO FRAGMENTENTRYLINK VALUES(94,0,'6ec871c4-5ded-994c-3565-20ffcf623233',32073,20117,16796623585306,20122,'Clarity Admin','2024-05-13 14:38:38.270000','2025-07-25 12:56:01.040000',32069,0,31988,20031,6,6,'.component-paragraph img {\u000a\u0009max-width: 100%;\u000a}','<div class="clearfix component-paragraph text-break" data-lfr-editable-id="element-text" data-lfr-editable-type="rich-text">\u000a\u0009A paragraph is a self-contained unit of a discourse in writing dealing with\u000a\u0009a particular point or idea. Paragraphs are usually an expected part of\u000a\u0009formal writing, used to organize longer prose.\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-text":{"sv_SE":"V\u00e4lkommen till Liferay","defaultValue":"\n\tA paragraph is a self-contained unit of a discourse in writing dealing with\n\ta particular point or idea. Paragraphs are usually an expected part of\n\tformal writing, used to organize longer prose.\n","pt_BR":"Bem vindo ao Liferay","fr_FR":"Bienvenue \u00e0 Liferay","ja_JP":"Liferay\u3078\u3088\u3046\u3053\u305d","ca_ES":"Benvingut, benvinguda a Liferay","de_DE":"Willkommen bei Liferay","hu_HU":"Isten hozott a Liferay-n\u00e9l!","ar_SA":"\u0623\u0647\u0644\u0627 \u0628\u0643\u0645 \u0641\u064a Liferay","fi_FI":"Liferay toivottaa tervetulleeksi","en_US":"Welcome to the Client Extensions Course!","es_ES":"Bienvenido a Liferay","zh_CN":"\u6b22\u8fce\u6765\u5230Liferay","config":{"mapperType":"link"},"nl_NL":"Welkom bij Liferay"}}}','tdla',0,'BASIC_COMPONENT-paragraph',1,'2025-07-25 12:56:01.039000',NULL,'6ec871c4-5ded-994c-3565-20ffcf623233')
