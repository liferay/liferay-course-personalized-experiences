INSERT INTO DDMFIELDATTRIBUTE VALUES(0,0,3851,16796623585306,3223,63562,NULL,'en_US','<p data-renderer-start-pos="3542">This toolkit includes the latest brochures, product highlights, and pricing information to support your conversations with clients. Download print-ready materials or share digital versions with your network. Stay updated with seasonal campaigns and new releases to maximize sales potential.</p>\u000a\u000a<p data-renderer-start-pos="3834">All files are updated quarterly and available in English, Spanish, and Portuguese.</p>',NULL)
