INSERT INTO FRAGMENTENTRYLINK VALUES(94,0,'4e03f3b7-9d1a-1ff1-a6cb-1d0e5f5dfa3a',34518,32106,16796623585306,20122,'Clarity Admin','2024-05-20 20:56:56.451000','2025-07-25 12:56:01.596000',34502,0,32588,20031,45,45,'.component-paragraph img {\u000a\u0009max-width: 100%;\u000a}','<div class="clearfix component-paragraph text-break" data-lfr-editable-id="element-text" data-lfr-editable-type="rich-text">\u000a\u0009A paragraph is a self-contained unit of a discourse in writing dealing with\u000a\u0009a particular point or idea. Paragraphs are usually an expected part of\u000a\u0009formal writing, used to organize longer prose.\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-text":{"defaultValue":"\n\tA paragraph is a self-contained unit of a discourse in writing dealing with\n\ta particular point or idea. Paragraphs are usually an expected part of\n\tformal writing, used to organize longer prose.\n","config":{"mapperType":"link"}}}}','jait',1,'BASIC_COMPONENT-paragraph',1,'2025-07-25 12:56:01.596000',NULL,'4e03f3b7-9d1a-1ff1-a6cb-1d0e5f5dfa3a')
