get.hasAttribute(''data-lfr-editable-id'') ||\u000a\u0009\u0009target.hasAttribute(''contenteditable'');\u000a\u000a\u0009if (isEditable && layoutMode === ''edit'') {\u000a\u0009\u0009return;\u000a\u0009}\u000a\u000a\u0009if (isMultistepButton) {\u000a\u0009\u0009Liferay.fire(''formFragment:changeStep'', {\u000a\u0009\u0009\u0009emitter: fragmentElement,\u000a\u0009\u0009\u0009step: configuration.type,\u000a\u0009\u0009});\u000a\u0009}\u000a\u0009else {\u000a\u0009\u0009Liferay.fire(''formFragment:submit'');\u000a\u0009}\u000a});','{\u000a\u0009"fieldSets": [\u000a\u0009\u0009{\u000a\u0009\u0009\u0009"fields": [\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "submit",\u000a\u0009\u0009\u0009\u0009\u0009"label": "type",\u000a\u0009\u0009\u0009\u0009\u0009"name": "type",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "previous"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "next"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "submit"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "approved",\u000a\u0009\u0009\u0009\u0009\u0009"label": "submitted-entry-status",\u000a\u0009\u0009\u0009\u0009\u0009"name": "submittedEntryStatus",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "approved",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "0"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "draft",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "2"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "primary",\u000a\u0009\u0009\u0009\u0009\u0009"label": "style",\u000a\u0009\u0009\u0009\u0009\u0009"name": "buttonType",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "primary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "secondary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "outline-primary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "outline-secondary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "nm",\u000a\u0009\u0009\u0009\u0009\u0009"label": "size",\u000a\u0009\u0009\u0009\u0009\u0009"name": "buttonSize",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "small",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "sm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "normal",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "nm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "large",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "lg"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009]\u000a\u0009\u0009}\u000a\u0009]\u000a}','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"next-button-text":{"defaultValue":"\n\t\t\t\tNext\n\t\t\t","config":{}},"previous-button-text":{"defaultValue":"\n\t\t\t\tPrevious\n\t\t\t","config":{}},"submit-button-text":{"defaultValue":"\n\t\tSubmit\n\t","config":{}}},"com.liferay.fragment.entry.processor.freemarker.FreeMarkerFragmentEntryProcessor":{"buttonType":"primary","submittedEntryStatus":"approved","buttonSize":"nm"}}','tshb',0,'INPUTS-submit-button',3,'2025-07-25 12:56:00.724000',NULL,'09d96709-4d67-536e-cd0f-b9f4ec7e4a5d')
